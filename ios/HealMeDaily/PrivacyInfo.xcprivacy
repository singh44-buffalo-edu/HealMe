<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- No tracking, no third-party data flows: health data moves only
         between this app and the user's own self-hosted server. -->
    <key>NSPrivacyTracking</key>
    <false/>
    <key>NSPrivacyTrackingDomains</key>
    <array/>
    <!-- Nothing is "collected" in the App Privacy sense: the developer
         operates no server; data goes to infrastructure the user owns.
         See APPSTORE.md for the App Privacy questionnaire answers. -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1: app's own settings (server URL, toggles). -->
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
