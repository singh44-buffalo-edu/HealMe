# HealMeDaily environment template. scripts/bootstrap.py copies this to .env
# (gitignored) on first run and fills in ids/secrets; every key used anywhere
# must stay mirrored here WITHOUT its real value (CLAUDE.md §6: secrets live
# only in .env, never in code, never committed).
# Consumers: scripts/* (python-dotenv), ai-service settings (env_file),
# frontend build (VITE_* only, baked in at build time), and
# infra/docker-compose.app.yml (env_file for the AI container).

# Medplum stack (safe local defaults; never put real secrets in this file)
# Informational — infra/docker-compose.yml pins images to this version explicitly.
MEDPLUM_VERSION=5.1.26
MEDPLUM_BASE_URL=http://localhost:8103/
# ClientApplication credentials for the ai-service's OAuth2 client-credentials
# grant — written by bootstrap; scoped by the least-privilege AccessPolicy.
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=
# The single owner Patient — written by seed.py after conditional create.
MEDPLUM_PATIENT_ID=

# Used only if the seed script must conditionally create the single Patient.
HMD_PATIENT_IDENTIFIER=healmedaily-user
HMD_PATIENT_GIVEN_NAME=HealMeDaily
HMD_PATIENT_FAMILY_NAME=User

# Browser-safe configuration (VITE_ prefix = shipped to the browser and baked
# in at BUILD time — a change needs a rebuild/dev-server restart; never put
# anything secret behind a VITE_ key).
VITE_MEDPLUM_BASE_URL=http://localhost:8103/
VITE_AI_SERVICE_URL=http://localhost:8000/

# FastAPI
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=8000
AI_ALLOWED_ORIGINS=http://localhost:5173
# Session gate: every endpoint except /health requires a valid Medplum access
# token (the web app and iOS app forward theirs automatically). Leave ON —
# the service can export the whole record. Only set false on a fully-loopback
# dev box.
AI_REQUIRE_AUTH=true
# Owner-authorization allowlist (auth.py). Comma-separated FHIR profile
# references the caller's session must match (e.g.
# "Practitioner/<id>,Patient/<id>"). Empty ⇒ authenticate-only: any valid
# Medplum session passes (fine while you are the only user). Set it before
# giving care-circle members Medplum logins, so a scoped token can't reach
# the AI service's full-access endpoints. Find your reference in the Medplum
# app under your ProjectMembership → profile.
AI_OWNER_PROFILES=

# --- APNs push (iOS, Phase 7) — server-only Apple credentials -------------
# All optional: absent ⇒ push is "not configured" and the app still works.
# From the Apple Developer portal: an APNs Auth Key (.p8) + its Key ID, your
# Team ID, and the app's bundle id. The .p8 is a SECRET — never ships in the
# app. Provide it as a file path OR inline PEM (\n-escaped).
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.healmedaily.app
APNS_KEY_PATH=./data/secrets/AuthKey.p8
# APNS_KEY_P8=
# 'sandbox' for development-signed builds, 'production' for TestFlight/App
# Store. The per-device value the app registers overrides this.
# Shared secret the push Subscription presents to /push/dispatch (that one
# endpoint is called by the Medplum server, not a user). Generate a long
# random value; it must match what deploy_bots wires into the Subscription.
PUSH_SUBSCRIPTION_SECRET=
# The URL the Medplum SERVER can reach the ai-service at (for the push
# Subscription rest-hook). On Docker Desktop the server reaches the host via
# host.docker.internal; in cloud it is the ai.<domain> URL. Empty ⇒ the push
# Subscription is not wired by deploy_bots.
AI_SERVICE_PUBLIC_URL=http://host.docker.internal:8000
# Watched-folder ingestion: files dropped here are auto-imported on a scan
# loop (deterministic importers commit directly; AI extractions still go
# through the review queue). Relative paths resolve against the repo root.
INGEST_WATCH_DIR=./data/inbox
INGEST_SCAN_SECONDS=60

# AI is optional. Leave AI_PROVIDER empty to run with AI disabled.
# Supported values: anthropic, openai, gemini, ollama
# Keys can also be stored via the AI Settings API (POST /ai/keys/{provider}) —
# macOS Keychain when available, else data/secrets/ai-keys.json (0600, gitignored).
# Stored keys take precedence over these env vars. Per-feature routing
# (local/cloud/off) persists in data/secrets/ai-settings.json; while that file
# is absent everything follows AI_PROVIDER.
AI_PROVIDER=
AI_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/

# Product preferences; owner-confirmed at Phase 1 sign-off (2026-07-13): kg, 24h, 90-day window.
HMD_TIME_ZONE=America/Los_Angeles
HMD_WEIGHT_UNIT=kg
HMD_CLOCK_FORMAT=24h
HMD_HEALTH_REVIEW_DAYS=90

# Bootstrap (scripts/bootstrap.py): first-user registration on the local Medplum.
# Password is generated and stored in .env on first run if left empty — local dev only.
# NOTE: infra/docker-compose.yml ships with self-registration DISABLED
# (MEDPLUM_REGISTER_ENABLED 'false', Phase 9 hardening); a fresh install must
# temporarily flip it to 'true' for the one-time `make bootstrap`, then back.
HMD_ADMIN_EMAIL=
HMD_ADMIN_PASSWORD=
MEDPLUM_PROJECT_ID=
# Instance super admin (Medplum seeds admin@example.com/medplum_admin on first
# boot of a fresh self-hosted instance). Needed only for project-feature
# changes (e.g. enabling bots). Hardening: `make rotate-superadmin` replaces
# the factory default with a generated password and stores it here (in .env).
HMD_SUPERADMIN_EMAIL=admin@example.com
HMD_SUPERADMIN_PASSWORD=medplum_admin

# Backups (scripts/backup.py / `make backup`): Postgres dump + binary storage
# tar, timestamped under this directory (inside gitignored data/ by default).
HMD_BACKUP_DIR=./data/backups

# --- Cloud deployment (infra/docker-compose.cloud.yml — see DEPLOYMENT.md) ---
# Only needed for Option B (own VM). All four subdomains derive from this:
# app.{domain} / fhir.{domain} / medplum.{domain} / ai.{domain}
HMD_DOMAIN=
HMD_ACME_EMAIL=
# Strong random values — the dev defaults must never reach a public machine.
HMD_DB_PASSWORD=
HMD_REDIS_PASSWORD=
